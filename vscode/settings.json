{
    // --- EDITOR SETTINGS ---
    "editor.fontFamily": "'JetBrains Mono',  'Fira Code', Inconsolata, 'Cascadia Code', monospace",
    "editor.fontLigatures": true,
    "editor.fontWeight": "400",
    "editor.lineHeight": 22,
    "editor.renderWhitespace": "all",
    "editor.accessibilitySupport": "off",
    "editor.suggestSelection": "first",
    "editor.inlineSuggest.enabled": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.stickyScroll.enabled": true,

    // --- TERMINAL SETTINGS ---
    "terminal.integrated.fontFamily": "'Cascadia Code', 'Symbols Nerd Font Mono', monospace",
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.defaultProfile.windows": "PowerShell",

    // --- WORKBENCH & THEMING ---
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.colorTheme": "Gruvbox Dark Hard",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.productIconTheme": "fluent-icons",

    // --- FILES, EXPLORER & WORKSPACE ---
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    "files.refactoring.autoSave": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.compactFolders": false,
    "security.workspace.trust.untrustedFiles": "open",

    // --- GIT, SCM & AI INTEGRATION ---
    "git.autofetch": true,
    "scm.inputFontSize": 12,
    "gitlens.advanced.messages": {
        "suppressGitVersionWarning": true
    },
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },

    // --- FORMATTING & LANGUAGE SETTINGS ---
    "html.format.enable": true,
    "html.format.indentHandlebars": true,
    "html.format.indentInnerHtml": true,
    "eslint.format.enable": true,
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "[scss]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features",
        "editor.formatOnPaste": true
    },
    "[markdown]": {
        "editor.defaultFormatter": "vscode.markdown-language-features",
        "editor.wordWrap": "on",
        "editor.renderWhitespace": "all",
        "editor.acceptSuggestionOnEnter": "smart"
    },
    "chat.viewSessions.orientation": "stacked"
}